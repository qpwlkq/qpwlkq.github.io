---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Qinpeng">
  <main class="page-shell">
    <section class="page-hero compact">
      <p class="section-kicker">About</p>
      <h1>A personal profile with a pulse.</h1>
      <p>
        This page is reserved for the parts that do not fit neatly into a resume: taste, craft, momentum,
        and the ideas that keep returning.
      </p>
    </section>
    <section class="essay-layout">
      <p>
        Add a short narrative here: what you build, what you care about, what kind of problems you enjoy,
        and what you want this site to say before someone reads a single article.
      </p>
      <p>
        The structure is intentionally plain for now, so the visual language can grow from real content
        instead of filling space with decoration.
      </p>
    </section>
  </main>
</BaseLayout>
