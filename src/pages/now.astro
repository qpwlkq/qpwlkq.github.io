---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Now | Qinpeng">
  <main class="page-shell">
    <section class="page-hero compact">
      <p class="section-kicker">Now</p>
      <h1>Current state, not a permanent biography.</h1>
      <p>What is active, what is being learned, and what deserves attention this season.</p>
    </section>
    <section class="timeline">
      <article>
        <span>Focus</span>
        <p>Building a personal web presence that can hold writing, projects, and expressive interfaces.</p>
      </article>
      <article>
        <span>Learning</span>
        <p>Astro, content collections, interactive islands, and a visual system that feels personal.</p>
      </article>
      <article>
        <span>Next</span>
        <p>Replace placeholders with real biography, works, and a stronger homepage direction.</p>
      </article>
    </section>
  </main>
</BaseLayout>
